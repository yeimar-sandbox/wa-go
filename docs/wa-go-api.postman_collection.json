{
  "info": {
    "name": "Wa Go API",
    "description": "WhatsApp Gateway API ",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "adminKey",
      "value": "change-me"
    },
    {
      "key": "instanceToken",
      "value": ""
    },
    {
      "key": "instanceId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Instances (Admin)",
      "item": [
        {
          "name": "Create Instance",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/instances/",
            "header": [
              {
                "key": "apikey",
                "value": "{{adminKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Instance\",\n  \"token\": \"my-secret-token\"\n}"
            }
          }
        },
        {
          "name": "List Instances",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/instances/",
            "header": [
              {
                "key": "apikey",
                "value": "{{adminKey}}"
              }
            ]
          }
        },
        {
          "name": "Get Instance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/instances/{{instanceId}}",
            "header": [
              {
                "key": "apikey",
                "value": "{{adminKey}}"
              }
            ]
          }
        },
        {
          "name": "Delete Instance",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/instances/{{instanceId}}",
            "header": [
              {
                "key": "apikey",
                "value": "{{adminKey}}"
              }
            ]
          }
        }
      ]
    },
